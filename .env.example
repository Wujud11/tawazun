# ── Backend (server/.env or Render environment variables) ─────────────────────

# Required — OpenAI API key used by the netting analysis route
OPENAI_API_KEY=sk-...

# Required on Render — URL of the deployed frontend (no trailing slash)
# Used by the Express CORS allowlist so the frontend can reach the API
# Example: https://tawazun.vercel.app
FRONTEND_URL=

# Optional — defaults to 3001 locally; Render sets this automatically
PORT=3001

# ── Frontend (Vite build environment variables) ────────────────────────────────

# Required in production — full URL of the Render backend (no trailing slash)
# Leave empty for local dev; the Vite proxy handles /api/* automatically
# Example: https://tawazun-api.onrender.com
VITE_API_URL=
