# ── Backend (local .env or Fly secrets) ──────────────────────────────────────

# Required — OpenAI API key used by the netting analysis route
OPENAI_API_KEY=sk-...

# Optional — defaults to 3001 locally; Fly sets PORT automatically in production
PORT=3001

# ── Frontend (Vite build environment variables) ────────────────────────────────

# Optional — only set when frontend is hosted separately from the backend
# Leave empty when both are served from the same Fly.io service
VITE_API_URL=

# Optional — only needed when frontend and backend run on different origins
FRONTEND_URL=
